DATABASE_URL=
ANTHROPIC_API_KEY=
# Voice-note transcription (Groq Whisper, free tier). Optional — without it voice
# notes still flow through with a placeholder transcript. Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_CHAT_ID=
# Protects POST /api/admin/prices. Leave blank in dev = open.
ADMIN_SECRET=
# When true, the agent runner uses Claude Managed Agents Sessions
# (beta: managed-agents-2026-04-01) instead of the Messages + tool_use loop.
# Falls back to messages+tools on any error.
USE_MANAGED_AGENTS=
